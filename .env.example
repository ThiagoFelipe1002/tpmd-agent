# Provedor de IA: openai ou gemini
AI_PROVIDER=openai

# Chave OpenAI (necessária se AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Chave Gemini (necessária se AI_PROVIDER=gemini)
# Obtenha gratuitamente em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Caminho para a pasta raiz com os arquivos de conteúdo (.vtt/.pdf)
COURSE_PATH=C:\caminho\para\pasta\de\conteudo

# Pasta onde os markdowns gerados serão salvos
DOCS_OUTPUT_PATH=data/docs

# Pasta onde o índice FAISS será salvo
VECTORSTORE_PATH=vectorstore

# Modelo para geração de documentação (pode usar GPT-4.1-mini ou GPT-4.1-mini-mini)
DOC_GEN_MODEL=gpt-4.1-mini

# Modelo para o agente RAG
AGENT_MODEL=gpt-4.1-mini

# Modelo de embeddings
EMBEDDING_MODEL=text-embedding-3-small
